# ─── Database (Neon PostgreSQL - serverless, auto-wakes) ──
# Pooled URL (for Prisma queries):
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.us-east-1.aws.neon.tech/dbname?pgbouncer=true&sslmode=require"
# Direct URL (for migrations):
DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/dbname?sslmode=require"

# ─── Email (Resend) ──────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@newcanadiandrywall.ca"
ADMIN_EMAIL="you@yourdomain.com"

# ─── Media Storage (Vercel Blob) ─────────────────────
# Get your token at https://vercel.com → Storage → Blob → Create Store
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── User Auth (NextAuth v5 — Google OAuth + Email) ──
# Google OAuth: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"
# NextAuth signing secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="https://www.newcanadiandrywall.ca"

# ─── Admin Panel ─────────────────────────────────────
ADMIN_PASSWORD="change-this-in-production"
AUTH_SECRET="generate-a-random-secret-here"
