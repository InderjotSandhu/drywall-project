generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

// ──────────────────────────────────────────────
// Projects
// ─────────────────────────────────────────────
model Project {
  id          Int       @id @default(autoincrement())
  title       String
  category    String
  description String
  location    String?
  image       String
  imageAlt    String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  images      ProjectImage[]
  videos      ProjectVideo[]
  stats       ProjectStat[]
}

model ProjectImage {
  id        Int     @id @default(autoincrement())
  url       String
  order     Int     @default(0)
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectVideo {
  id        Int     @id @default(autoincrement())
  url       String
  order     Int     @default(0)
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectStat {
  id        Int     @id @default(autoincrement())
  label     String
  value     String
  order     Int     @default(0)
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// Testimonials
// ──────────────────────────────────────────────
model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  quote     String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────────
// Services
// ──────────────────────────────────────────────
model Service {
  id          String   @id
  title       String
  description String
  detail      String
  order       Int      @default(0)
  isActive    Boolean  @default(true)

  tags        ServiceTag[]
  features    ServiceFeature[]
}

model ServiceTag {
  id        Int     @id @default(autoincrement())
  label     String
  order     Int     @default(0)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model ServiceFeature {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  order       Int     @default(0)
  serviceId   String
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// Collaborations / Partners
// ──────────────────────────────────────────────
model Collaboration {
  id          Int      @id @default(autoincrement())
  name        String
  logo        String
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ──────────────────────────────────────────────
// Contact Submissions — Quote Requests
// ──────────────────────────────────────────────
model QuoteSubmission {
  id          Int      @id @default(autoincrement())
  userId      String?
  name        String
  email       String
  phone       String?
  projectType String
  budget      String?
  message     String
  status      String   @default("new")
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
}

// ──────────────────────────────────────────────
// Contact Submissions — Career Applications
// ──────────────────────────────────────────────
model CareerSubmission {
  id           Int      @id @default(autoincrement())
  userId       String?
  name         String
  email        String
  phone        String?
  role         String
  experience   String?
  availability String?
  message      String
  resumeUrl    String?
  status       String   @default("new")
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id])
}

// ──────────────────────────────────────────────
// User Accounts (NextAuth v5)
// ──────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  quotes   QuoteSubmission[]
  careers  CareerSubmission[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ──────────────────────────────────────────────
// Admin — stored password hash for admin panel
// ──────────────────────────────────────────────
model Admin {
  id           Int      @id @default(autoincrement())
  passwordHash String
  updatedAt    DateTime @updatedAt
}


